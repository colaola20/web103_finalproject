{
  "name": "fun",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "npm run build -w frontend",
    "start": "npm start -w backend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "npm start -w backend",
    "client": "npm run dev -w frontend"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}